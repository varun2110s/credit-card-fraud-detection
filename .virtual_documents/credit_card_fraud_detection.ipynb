fraud = df[df['class'] == 1]
normal = df[df['class'] == 0]
print(fraud.shape , normal.shape)


plt.hist(fraud['amount'] , bins=50 , label='fraud')
plt.hist(normal['amount'] , bins=50 , label ='normal')
plt.legend()
